@page
@model ProyectoPanaderia.Pages.ReposteriaModel
@{
    ViewData["Title"] = "Panadería";
}


<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Archivo de estilos personalizados -->
    <link rel="stylesheet" href="~/css/Reposteria.css">
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg bg-light fixed-top">
        <div class="container-fluid">
            <a class="navbar-brand" href="#">Reposteria</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                    aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link active" asp-page="/Index">Inicio</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Panaderia">Panadería</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Reposteria">Repostería</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Carro">Carro</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Login_Registrar">Registro</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Contenido Principal -->
    <main class="container mt-5 pt-4">
        <h1 class="text-center"> Reposteria </h1>
        <p class="text-center">Explora nuestros deliciosos productos.</p>

        <!-- Contenedor de Tarjetas -->
        <div class="row">
            <!-- Tarjeta 1 -->
            <div class="col-md-4">
                <div class="card">
                    <img src="https://via.placeholder.com/300" class="card-img-top" alt="Tarta de Fresas">
                    <div class="card-body">
                        <h5 class="card-title">Tarta de Fresas</h5>
                        <p class="card-text">Una deliciosa tarta con fresas frescas y crema pastelera.</p>
                        <a href="#" class="btn btn-primary">Ver más</a>
                    </div>
                </div>
            </div>

            <!-- Tarjeta 2 -->
            <div class="col-md-4">
                <div class="card">
                    <img src="https://via.placeholder.com/300" class="card-img-top" alt="Muffins de Chocolate">
                    <div class="card-body">
                        <h5 class="card-title">Muffins de Chocolate</h5>
                        <p class="card-text">Esponjosos muffins con chispas de chocolate y un toque de vainilla.</p>
                        <a href="#" class="btn btn-primary">Ver más</a>
                    </div>
                </div>
            </div>

            <!-- Tarjeta 3 -->
            <div class="col-md-4">
                <div class="card">
                    <img src="https://via.placeholder.com/300" class="card-img-top" alt="Cheesecake de Frutos Rojos">
                    <div class="card-body">
                        <h5 class="card-title">Cheesecake de Frutos Rojos</h5>
                        <p class="card-text">Suave cheesecake con una deliciosa cobertura de frutos rojos.</p>
                        <a href="#" class="btn btn-primary">Ver más</a>
                    </div>
                </div>
            </div>

    </main>

    <!-- Footer -->
    <footer class="bg-light text-center py-3 fixed-bottom">
        <p>&copy; @DateTime.Now.Year - Mi Sitio Web</p>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Archivo de scripts personalizados -->
    <script src="~/js/site.js" asp-append-version="true"></script>

</body>
</html>
