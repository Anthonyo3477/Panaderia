@page
@model ProyectoPanaderia.Pages.CarroModel
@{
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Tu archivo de estilos personalizados -->
    <link rel="stylesheet" href="~/css/Carro.css">
</head>
<body>

    <!-- Navbar (barra de navegación) -->
    <nav class="navbar navbar-expand-lg bg-light fixed-top">
        <div class="container-fluid">
            <a class="navbar-brand" href="#">Panaderia</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                    aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link active" asp-page="/Index">Inicio</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Panaderia">Panadería</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Reposteria">Repostería</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Carro">Carro</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Login_Registrar">Registro</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Contenido Principal -->
    <main class="container mt-5">
        <h1 class="text-center">Carro</h1>
        <p class="text-center"> Este es el carrito, aqui puedes ver tus pedidos y tus copras </p>

        <!-- Sección vacía para contenido -->
        <div class="row">
            <div class="col-md-12">
                <!-- Agrega tu contenido aquí -->
            </div>
        </div>
    </main>

    <!-- Footer -->
    <footer class="bg-light text-center py-3 fixed-bottom">
        <p>&copy; @DateTime.Now.Year - Mi Sitio Web</p>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Tu archivo de scripts personalizados -->
    <script src="~/js/site.js"></script>

</body>
</html>
